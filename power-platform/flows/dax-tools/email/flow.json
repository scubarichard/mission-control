{
  "properties": {
    "connectionReferences": {},
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$authentication": {"defaultValue": {}, "type": "SecureObject"},
        "$connections": {"defaultValue": {}, "type": "Object"}
      },
      "triggers": {
        "manual": {
          "type": "Request", "kind": "Skills",
          "inputs": {"schema": {"type": "object", "properties": {"count": {"type": "integer", "title": "How many emails", "description": "Number of recent emails to return (default 5)", "x-ms-dynamically-added": true}, "search": {"type": "string", "title": "Search query (optional)", "description": "Optional search string (sender, subject, content)", "x-ms-content-hint": "TEXT", "x-ms-dynamically-added": true}}}},
          "description": "Read recent emails from advisor's Outlook inbox via Microsoft Graph."
        }
      },
      "actions": {
        "Scope": {
          "type": "Scope",
          "actions": {
            "Get_Graph_Token": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://login.microsoftonline.com/d2a3c346-00f3-47dd-a53e-caa3fca74714/oauth2/v2.0/token",
                "headers": {"Content-Type": "application/x-www-form-urlencoded"},
                "body": "grant_type=client_credentials&client_id=37fe1021-88b3-4744-aa32-b5d7e104462b&client_secret=__PP_CI_SECRET__&scope=https%3A%2F%2Fgraph.microsoft.com%2F.default"
              }
            },
            "Get_Inbox": {
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://graph.microsoft.com/v1.0/users/1740bd16-eb72-4ace-913d-96150cec19fd/messages?$top=@{coalesce(triggerBody()?['count'],5)}&$orderby=receivedDateTime desc@{if(equals(triggerBody()?['search'],null),'',concat('&$search=%22',encodeUriComponent(triggerBody()?['search']),'%22'))}&$select=subject,from,receivedDateTime,bodyPreview,isRead,webLink",
                "headers": {"Authorization": "Bearer @{body('Get_Graph_Token')?['access_token']}", "ConsistencyLevel": "eventual"}
              },
              "runAfter": {"Get_Graph_Token": ["Succeeded"]}
            }
          }
        },
        "Respond_to_the_agent": {
          "type": "Response", "kind": "Skills",
          "inputs": {
            "statusCode": 200,
            "body": {"messages": "@body('Get_Inbox')?['value']", "asOf": "@utcNow()"},
            "schema": {"type": "object", "properties": {
              "messages": {"title": "Messages", "type": "array", "x-ms-dynamically-added": true},
              "asOf": {"title": "As of", "type": "string", "x-ms-content-hint": "TEXT", "x-ms-dynamically-added": true}
            }}
          },
          "runAfter": {"Scope": ["Succeeded"]}
        }
      }
    },
    "templateName": null
  },
  "schemaVersion": "1.0.0.0"
}
