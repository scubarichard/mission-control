# LibreChat environment variables — template
# Copy to .env and fill in per-client values (or inject via Container App secrets)

# ---------- App ----------
HOST=0.0.0.0
PORT=3080
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=true

# ---------- Azure OpenAI ----------
OPENAI_API_KEY=__from_keyvault__
AZURE_OPENAI_API_INSTANCE_NAME=__client_instance__
AZURE_API_VERSION=2024-08-01-preview
AZURE_OPENAI_MODELS=gpt-4o

# ---------- Entra ID (OpenID Connect) ----------
# Deploy-EntraApp.ps1 stores these in Key Vault; Container App injects them at runtime.
OPENID_ISSUER=https://login.microsoftonline.com/__CLIENT_TENANT_ID__/v2.0
OPENID_CLIENT_ID=__from_keyvault:entra-client-id__
OPENID_CLIENT_SECRET=__from_keyvault:entra-client-secret__
OPENID_SCOPE=openid profile email
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_BUTTON_LABEL=Sign in with Microsoft

# ---------- Session ----------
# Seeded by key-vault.bicep, replaced by Deploy-LibreChatSecrets.ps1 with crypto-random values.
JWT_SECRET=__from_keyvault:jwt-secret__
JWT_REFRESH_SECRET=__from_keyvault:jwt-refresh-secret__
CREDS_KEY=__from_keyvault:creds-key__
CREDS_IV=__from_keyvault:creds-iv__

# ---------- MongoDB ----------
MONGO_URI=__from_keyvault__

# ---------- Domain ----------
DOMAIN_CLIENT=https://__container_app_fqdn__
DOMAIN_SERVER=https://__container_app_fqdn__
