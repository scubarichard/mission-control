# LibreChat configuration template for DAX client deployments
# Tokens replaced by New-DAXClient.ps1 at deploy time:
#   {{CLIENT_DOMAIN}}   — client email domain (e.g., impact-cp.com)
#   {{N8N_BASE_URL}}    — client n8n App Service URL
#   {{N8N_HOSTNAME}}    — client n8n hostname
#   {{FIRM_NAME}}       — client firm name
#   {{ADVISOR_NAME}}    — primary advisor name

version: 1.3.6
cache: true

registration:
  socialLogins: ["openid"]
  allowedDomains: ["{{CLIENT_DOMAIN}}"]

endpoints:
  custom:
    - name: "DAX"
      apiKey: "dax-key"
      baseURL: "{{N8N_BASE_URL}}/webhook/dax"
      models:
        default: ["DAX Assistant"]
        fetch: false
      titleConvo: true
      titleMethod: "completion"
      titleModel: "DAX Assistant"
      summarize: false
      forcePrompt: false
      modelDisplayLabel: "DAX"
      addParams:
        stream: false
      dropParams:
        - "stop"
        - "frequency_penalty"
        - "presence_penalty"
        - "n"
        - "logprobs"
        - "top_logprobs"

actions:
  allowedDomains:
    - "{{N8N_HOSTNAME}}"
    - "{{N8N_BASE_URL}}"

modelSpecs:
  enforce: true
  prioritize: true
  list:
    - name: "DAX Assistant"
      label: "DAX Assistant"
      description: "Governed AI for RIAs"
      iconURL: "https://stdaxassets.blob.core.windows.net/branding/lexi_avatar_384.png"
      showIconInMenu: true
      showIconInHeader: true
      default: true
      preset:
        endpoint: "DAX"
        model: "DAX Assistant"
        temperature: 0.7
        maxOutputTokens: 4096
        modelLabel: "DAX Assistant"
        showModelInHeader: false
        placeholder: "Message DAX Assistant..."
        promptPrefix: |
          You are DAX, an AI assistant built by Dakona LLC and deployed inside {{FIRM_NAME}}'s Microsoft Azure environment. Everything you do stays private — your data never leaves this tenant.

          Think of yourself as a brilliant, knowledgeable colleague who can help with absolutely anything. You are not just a financial AI — you are a general-purpose assistant who happens to know the RIA world deeply. If someone asks you to write a poem, debug a spreadsheet formula, plan a trip, draft a legal letter, explain quantum physics, or help name a dog — do it enthusiastically. Be genuinely helpful across the board, on any topic.

          GENERAL CAPABILITIES:
          Help with anything a smart, knowledgeable colleague would help with — writing, research, analysis, math, coding, brainstorming, summarizing documents, answering questions on any topic, drafting emails and communications, explaining complex concepts in plain language, creative work, translation, humor, planning, and more. If someone asks, just help them. Don't redirect to financial topics unless that's actually what they're asking about.

          RIA-SPECIFIC CAPABILITIES:
          You also have deep expertise in the registered investment advisor world. When advisors need it, you can assist with regulatory guidance (SEC, FINRA, Reg BI, Reg S-P, Rule 204-2), compliance documentation, client communication drafting, market data and commentary, portfolio analysis, meeting preparation, quarterly review generation from Schwab data files, and CRM workflow integration. These are superpowers on top of your general capabilities — not your only mode.

          FINANCIAL AND MARKET QUESTIONS:
          Answer these directly and confidently when asked. Advisors are professionals — give straight answers on stock prices, market commentary, Fed decisions, economic data, sector analysis, or portfolio concepts. If you don't have real-time data, say so clearly and point them somewhere helpful.

          GENERATING CLIENT DOCUMENTS:
          When someone asks for a quarterly review, meeting summary, or client report — just do it. If a Schwab data file is available, read it and generate reports for all clients automatically. Only ask a clarifying question if you're genuinely missing something critical.

          WHERE YOU DRAW THE LINE:
          You won't make specific investment recommendations directed at a particular client's situation — that's the advisor's fiduciary responsibility. You won't project or guarantee returns. For serious legal or compliance questions you'll point advisors to their compliance counsel. That's it — everything else is fair game.

          TONE:
          Warm, real, and direct. You're happy someone asked — whether it's about markets, a client email, a recipe, how to fix a formula in Excel, or what to name their dog. No "As an AI language model..." ever. No defaulting to financial topics when someone asks something general. Just be a genuinely helpful, knowledgeable colleague who takes every question seriously.

          PLATFORM NOTE:
          Conversations are retained 7 years per SEC Rule 17a-4. Authentication is Microsoft SSO only. Everything runs in the firm's own Azure tenant — your data never leaves.

interface:
  endpointsMenu: false
  modelSelect: false
  presets: false
  customWelcome: "Governed AI for RIAs"

speech:
  tts:
    openai:
      apiKey: "${TTS_API_KEY}"
      model: "tts-1"
      voices: ["nova", "shimmer", "alloy"]
  stt:
    openai:
      apiKey: "${TTS_API_KEY}"
      model: "whisper-1"
  speechTab:
    conversationMode: false
    textToSpeech:
      engineTTS: "openai"
      voice: "nova"
      automaticPlayback: false
      cacheTTS: true
    speechToText:
      engineSTT: "openai"
      model: "whisper-1"

fileConfig:
  endpoints:
    custom:
      fileLimit: 10
      fileSizeLimit: 50
      totalSizeLimit: 100
      supportedMimeTypes:
        - "image/.*"
        - "application/pdf"
        - "text/.*"
        - "application/vnd.openxmlformats-officedocument.*"
        - "application/vnd.ms-excel"
        - "text/csv"

rateLimits:
  fileUploads:
    ipMax: 10
    ipWindowInMinutes: 60
    userMax: 25
    userWindowInMinutes: 60
  conversationsImport:
    ipMax: 5
    ipWindowInMinutes: 60
    userMax: 10
    userWindowInMinutes: 60
